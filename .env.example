# Hleb Project Environment Configuration Example
# Copy this file to .env (cp .env.example .env) and fill in your actual values.

# --- Standard Hleb Settings (from existing .env) ---
# External port for the web server (Nginx)
SERVER_EXTERNAL_PORT=5125

# External port for the database (MariaDB)
DATABASE_EXTERNAL_PORT=3360

# External port for phpMyAdmin
PMA_EXTERNAL_PORT=8080

# --- Telegram Bot & Webhook Automation Settings ---
# Your Telegram Bot Token (REQUIRED - get this from BotFather)
TELEGRAM_BOT_TOKEN=""

# Path for the Telegram webhook (must match routes/map.php and config/telegram.php)
# The webhook-init service will append this to the localtunnel URL.
TELEGRAM_WEBHOOK_PATH="/telegram_bot_webhook"

# Base URL for your Mini App. This will be dynamically generated by localtunnel.
# Check the logs of the 'webhook-init' Docker service (`docker-compose logs webhook-init`) to get this value
# once localtunnel is running (e.g., https://yoursubdomain.loca.lt).
# This is mainly for reference or if you need to construct full URLs to the Mini App from the bot.
MINI_APP_BASE_URL=""

# --- Settings for the 'webhook-init' Docker service (automated webhook setup) ---
# Service name in docker-compose.yml that localtunnel should target
TARGET_SERVICE_HOST="nginx"
# Internal port of that target service
TARGET_SERVICE_PORT="80"

# Optional: Preferred localtunnel subdomain (not guaranteed for free version)
# LT_SUBDOMAIN="yourshopname"
# Optional: Max retries for localtunnel connection by webhook-init script
# MAX_LT_RETRIES="3"
# Optional: Timeout in seconds for localtunnel to provide a URL
# LT_START_TIMEOUT="20"

# --- Shop Database Settings (MariaDB/MySQL) ---
# These are from the existing .env file.
# If your shop uses a different database or credentials, update accordingly.
MYSQL_DATABASE="hleb"
MYSQL_USER="hleb"
MYSQL_PASSWORD="toaster"

# --- Shop Application Settings (loaded by hleb/config/shop.php) ---
SHOP_CURRENCY="RUB"
SHOP_ITEMS_PER_PAGE="12"

# Example: Payment Gateway (Test Gateway) - Uncomment and set if used
# TEST_GATEWAY_API_KEY=""
# TEST_GATEWAY_SECRET_KEY=""
# TEST_GATEWAY_ENDPOINT="https://example.com/api/payment"

# --- AI Service Settings (loaded by hleb/config/shop.php) ---
# Uncomment and set if used
# AI_SERVICE_ENDPOINT=""
# AI_SERVICE_API_KEY=""

# --- General Hleb Application Settings (usually in hleb/config/common.php or main.php, may load from .env) ---
# APP_DEBUG=true # Set to false in production. Hleb's common.php uses env_bool('APP_DEBUG', true)
# APP_ENV="local" # Example: 'local', 'development', 'production'
# APP_KEY="" # If Hleb uses an application key for encryption, generate one.
# APP_LOG_LEVEL="info" # Example, see hleb/config/common.php
